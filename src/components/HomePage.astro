---
import type { Lang } from '../i18n';
import { t } from '../i18n';
import { wines } from '../content/wines';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tags = ['ponca', 'altitude', 'organic', 'yeasts'] as const;
---

<article class="max-w-5xl mx-auto px-6">

  <section class="pt-16 pb-10 sm:pt-24 sm:pb-14">
    <h1 class="font-serif text-2xl sm:text-3xl text-gray-900 max-w-2xl leading-snug">
      {t(lang, 'hero.text')}
    </h1>
    <p class="mt-3 text-sm text-gray-400">{t(lang, 'hero.location')}</p>
  </section>

  <div class="aspect-[21/9] bg-gray-100 rounded overflow-hidden mb-12">
    <img src="/images/andrej-vigna.jpg" alt="Andrej Kristancic in the vineyard, Goriška Brda" class="w-full h-full object-cover" loading="eager" onerror="this.style.display='none'" />
  </div>

  <section class="pb-10">
    <p class="text-base leading-relaxed text-gray-600 max-w-prose">
      {t(lang, 'place.text')}
    </p>
  </section>

  <div class="grid grid-cols-2 gap-[1px] bg-gray-200 rounded overflow-hidden mb-10">
    <div class="aspect-[4/3] bg-gray-100">
      <img src="/images/ponca.jpg" alt="Ponca soil" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
    </div>
    <div class="aspect-[4/3] bg-gray-100">
      <img src="/images/vigna.jpg" alt="Vineyard rows" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
    </div>
  </div>

  <div class="flex flex-wrap gap-2 mb-8">
    {tags.map((tag) => (
      <span class="text-xs text-gray-500 border border-gray-200 rounded px-2.5 py-1">
        {t(lang, `tags.${tag}`)}
      </span>
    ))}
  </div>

  <section class="pb-10">
    <p class="text-base leading-relaxed text-gray-600 max-w-prose">
      {t(lang, 'method.text')}
    </p>
  </section>

  <div class="aspect-[16/9] bg-gray-100 rounded overflow-hidden mb-12">
    <img src="/images/cantina.jpg" alt="Cellar" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
  </div>

  <hr class="border-gray-200 mb-16" />

  {/* — Wines — */}
  <section class="pb-10">
    <h2 class="text-xs tracking-[0.15em] uppercase text-gray-400 mb-12">
      {t(lang, 'wines.title')}
    </h2>

    <div class="space-y-16">
      {wines.map((wine, i) => (
        <div class:list={[
          "flex gap-8 sm:gap-12 items-start",
          i % 2 === 0 ? "flex-col sm:flex-row" : "flex-col sm:flex-row-reverse"
        ]}>
          <div class="w-full sm:w-64 md:w-72 flex-shrink-0">
            <div class="aspect-[3/4] bg-gray-50 rounded overflow-hidden">
              {wine.image ? (
                <img
                  src={wine.image}
                  alt={wine.name}
                  class="w-full h-full object-contain p-4"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-200 text-sm italic">
                  foto in arrivo
                </div>
              )}
            </div>
          </div>
          <div class="flex-1 sm:py-4">
            <h3 class="font-serif text-xl text-gray-900">{wine.name}</h3>
            <p class="text-xs text-gray-400 mt-1">
              {wine.grape} · {wine.type}{wine.format ? ` · ${wine.format}` : ''}
            </p>
            <p class="text-[15px] leading-relaxed text-gray-600 mt-4">
              {wine.descriptions[lang]}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* — Photos 5-6 — */}
  <div class="grid grid-cols-2 gap-[1px] bg-gray-200 rounded overflow-hidden my-16">
    <div class="aspect-[4/3] bg-gray-100">
      <img src="/images/vendemmia.jpg" alt="Harvest" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
    </div>
    <div class="aspect-[4/3] bg-gray-100">
      <img src="/images/andrej.jpg" alt="Andrej Kristancic" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
    </div>
  </div>

  <hr class="border-gray-200 mb-12" />

  <section class="pb-10">
    <p class="font-serif text-lg text-gray-800 mb-4 max-w-xs">
      {t(lang, 'contact.title')}
    </p>
    <address class="not-italic text-sm text-gray-500 leading-relaxed">
      <p>Plešivo, 5212 Dobrovo v Brdih</p>
      <p>Slovenia</p>
      <p class="mt-2">
        <a href={`mailto:${t(lang, 'contact.email')}`} class="text-gray-400 hover:text-gray-600 underline underline-offset-4 decoration-gray-300 transition-colors">
          {t(lang, 'contact.email')}
        </a>
      </p>
    </address>
  </section>

  <div class="aspect-[21/9] bg-gray-100 rounded overflow-hidden">
    <img src="/images/chiusura.jpg" alt="Goriška Brda" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
  </div>

</article>
