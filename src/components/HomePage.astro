---
import type { Lang } from '../i18n';
import { t, getLocalizedPath } from '../i18n';
import { wines } from '../content/wines';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tags = ['ponca', 'altitude', 'organic', 'yeasts'] as const;
---

<article class="max-w-5xl mx-auto px-6">

  {/* — Section 1: Hero — */}
  <section class="pt-16 pb-10 sm:pt-24 sm:pb-14">
    <h1 class="font-serif text-2xl sm:text-3xl text-gray-900 max-w-2xl leading-snug">
      {t(lang, 'hero.text')}
    </h1>
    <p class="mt-3 text-sm text-gray-400">{t(lang, 'hero.location')}</p>
  </section>

  {/* — Photo 1: Hero landscape — */}
  <div class="aspect-[21/9] bg-gray-100 rounded overflow-hidden mb-12">
    <img
      src="/images/andrej-vigna.jpg"
      alt="Andrej Kristancic in the vineyard, Goriška Brda"
      class="w-full h-full object-cover"
      loading="eager"
      onerror="this.style.display='none'"
    />
  </div>

  {/* — Section 2: The place — */}
  <section class="pb-10">
    <p class="text-base leading-relaxed text-gray-600 max-w-prose">
      {t(lang, 'place.text')}
    </p>
  </section>

  {/* — Photos 2-3: Ponca + Vineyard — */}
  <div class="grid grid-cols-2 gap-[1px] bg-gray-200 rounded overflow-hidden mb-10">
    <div class="aspect-[4/3] bg-gray-100">
      <img
        src="/images/ponca.jpg"
        alt="Ponca soil"
        class="w-full h-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="aspect-[4/3] bg-gray-100">
      <img
        src="/images/vigna.jpg"
        alt="Vineyard rows"
        class="w-full h-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>
  </div>

  {/* — Tags — */}
  <div class="flex flex-wrap gap-2 mb-8">
    {tags.map((tag) => (
      <span class="text-xs text-gray-500 border border-gray-200 rounded px-2.5 py-1">
        {t(lang, `tags.${tag}`)}
      </span>
    ))}
  </div>

  {/* — Section 3: Method — */}
  <section class="pb-10">
    <p class="text-base leading-relaxed text-gray-600 max-w-prose">
      {t(lang, 'method.text')}
    </p>
  </section>

  {/* — Photo 4: Cellar — */}
  <div class="aspect-[16/9] bg-gray-100 rounded overflow-hidden mb-12">
    <img
      src="/images/cantina.jpg"
      alt="Cellar"
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>

  <hr class="border-gray-200 mb-12" />

  {/* — Section 4: Wines — */}
  <section class="pb-10">
    <h2 class="text-xs tracking-[0.15em] uppercase text-gray-400 mb-8">
      {t(lang, 'wines.title')}
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-8">
      {wines.map((wine) => (
        <a href={getLocalizedPath(lang, `/wines/${wine.slug}`)} class="group block">
          <div class="aspect-[3/4] bg-gray-50 rounded overflow-hidden mb-3">
            {wine.image ? (
              <img
                src={wine.image}
                alt={wine.name}
                class="w-full h-full object-contain p-2 group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-300 text-xs">
                —
              </div>
            )}
          </div>
          <h3 class="font-serif text-sm text-gray-800 group-hover:text-gray-500 transition-colors">
            {wine.name}
          </h3>
          <p class="text-xs text-gray-400 mt-0.5">{wine.type}{wine.format ? ` — ${wine.format}` : ''}</p>
        </a>
      ))}
    </div>
  </section>

  {/* — Photos 5-6: Harvest + Andrej — */}
  <div class="grid grid-cols-2 gap-[1px] bg-gray-200 rounded overflow-hidden my-12">
    <div class="aspect-[4/3] bg-gray-100">
      <img
        src="/images/vendemmia.jpg"
        alt="Harvest"
        class="w-full h-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="aspect-[4/3] bg-gray-100">
      <img
        src="/images/andrej.jpg"
        alt="Andrej Kristancic"
        class="w-full h-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>
  </div>

  <hr class="border-gray-200 mb-12" />

  {/* — Section 5: Contact — */}
  <section class="pb-10">
    <p class="font-serif text-lg text-gray-800 mb-4 max-w-xs">
      {t(lang, 'contact.title')}
    </p>
    <address class="not-italic text-sm text-gray-500 leading-relaxed">
      <p>Plešivo, 5212 Dobrovo v Brdih</p>
      <p>Slovenia</p>
      <p class="mt-2">
        <a href={`mailto:${t(lang, 'contact.email')}`} class="text-gray-400 hover:text-gray-600 underline underline-offset-4 decoration-gray-300 transition-colors">
          {t(lang, 'contact.email')}
        </a>
      </p>
    </address>
  </section>

  {/* — Photo 7: Closing — */}
  <div class="aspect-[21/9] bg-gray-100 rounded overflow-hidden">
    <img
      src="/images/chiusura.jpg"
      alt="Goriška Brda"
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>

</article>
