---
import '../styles/global.css';
import { type Lang, languages, getLocalizedPath } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`https://nando.wine/${lang}${currentPath}`} />
    {Object.keys(languages).map((l) => (
      <link rel="alternate" hreflang={l} href={`https://nando.wine/${l}${currentPath}`} />
    ))}
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 bg-sand-50/95 backdrop-blur-sm border-b border-sand-200/60">
      <nav class="max-w-3xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href={getLocalizedPath(lang, '/')} class="font-serif text-lg tracking-wide text-sand-900 hover:text-sand-700 transition-colors">
          Nando
        </a>
        <div class="flex gap-3 text-xs text-sand-400">
          {Object.keys(languages).map((l) => (
            <a
              href={getLocalizedPath(l as Lang, currentPath)}
              class:list={[
                'transition-colors',
                l === lang
                  ? 'text-sand-700 underline underline-offset-4 decoration-sand-300'
                  : 'hover:text-sand-600',
              ]}
            >
              {l}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-sand-200/60 mt-16">
      <div class="max-w-3xl mx-auto px-5 py-4 flex justify-between text-[11px] text-sand-400">
        <span>Nando — Andrej Kristancic</span>
        <span>Goriška Brda</span>
      </div>
    </footer>
  </body>
</html>
