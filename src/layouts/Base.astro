---
import '../styles/global.css';
import { type Lang, languages, getLocalizedPath } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;1,8..60,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="canonical" href={`https://nando.wine/${lang}${currentPath}`} />
    {Object.keys(languages).map((l) => (
      <link rel="alternate" hreflang={l} href={`https://nando.wine/${l}${currentPath}`} />
    ))}
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={getLocalizedPath(lang, '/')} class="hover:opacity-70 transition-opacity">
          <img src="/images/logo-nando.jpg" alt="Nando — Goriška Brda" class="h-8 sm:h-10 w-auto" />
        </a>
        <div class="flex gap-3 text-xs text-gray-400">
          {Object.keys(languages).map((l) => (
            <a
              href={getLocalizedPath(l as Lang, currentPath)}
              onclick={`document.cookie='nando_lang=${l};path=/;max-age=31536000;SameSite=Lax'`}
              class:list={[
                'transition-colors',
                l === lang
                  ? 'text-gray-700 underline underline-offset-4 decoration-gray-300'
                  : 'hover:text-gray-600',
              ]}
            >
              {l}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between text-[11px] text-gray-400">
        <span>Nando — Andrej Kristancic</span>
        <span>Goriška Brda</span>
      </div>
    </footer>
  </body>
</html>
