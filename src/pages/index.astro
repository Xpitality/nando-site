---
// No server redirect — client-side detection handles it
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nando — Goriška Brda</title>
    <script is:inline>
      (function() {
        var supported = ['en', 'sl', 'it'];
        
        // 1. Check explicit user choice (cookie)
        var match = document.cookie.match(/nando_lang=(\w+)/);
        if (match && supported.indexOf(match[1]) !== -1) {
          window.location.replace('/' + match[1] + '/');
          return;
        }

        // 2. Auto-detect from browser
        var langs = navigator.languages || [navigator.language || 'en'];
        for (var i = 0; i < langs.length; i++) {
          var code = langs[i].toLowerCase().split('-')[0];
          if (supported.indexOf(code) !== -1) {
            window.location.replace('/' + code + '/');
            return;
          }
        }

        // 3. Fallback
        window.location.replace('/en/');
      })();
    </script>
  </head>
  <body></body>
</html>
