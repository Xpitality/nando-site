---
import Base from '../../../layouts/Base.astro';
import { wines } from '../../../content/wines';
import { t, getLocalizedPath } from '../../../i18n';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return wines.map((wine) => ({
    params: { slug: wine.slug },
    props: { wine },
  }));
};

const lang = 'it';
const { wine } = Astro.props;
---

<Base title={`${wine.name} — Nando`} description={wine.descriptions[lang]} lang={lang}>
  <article class="max-w-5xl mx-auto px-6 pt-16 pb-10">
    <a
      href={getLocalizedPath(lang, '/')}
      class="text-xs text-gray-400 hover:text-gray-600 transition-colors inline-flex items-center gap-1 mb-10"
    >
      &larr; {t(lang, 'wines.title')}
    </a>

    <div class="flex gap-10 items-start flex-col sm:flex-row">
      <div class="w-40 sm:w-52 flex-shrink-0 aspect-[3/4] bg-gray-50 rounded overflow-hidden">
        {wine.image ? (
          <img
            src={wine.image}
            alt={wine.name}
            class="w-full h-full object-contain p-3"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-gray-300 text-xs">—</div>
        )}
      </div>

      <div class="flex-1">
        <h1 class="font-serif text-2xl text-gray-900">{wine.name}</h1>

        <p class="text-base leading-relaxed text-gray-600 mt-6 max-w-md">
          {wine.descriptions[lang]}
        </p>

        <div class="flex gap-2 mt-6">
          <span class="text-xs text-gray-500 border border-gray-200 rounded px-2.5 py-1">{wine.type}</span>
          {wine.format && (
            <span class="text-xs text-gray-500 border border-gray-200 rounded px-2.5 py-1">{wine.format}</span>
          )}
        </div>
      </div>
    </div>
  </article>
</Base>
